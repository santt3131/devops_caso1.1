pipeline {
    agent none 

    stages {
        // ETAPA 1: DESCARGA
        stage('Get Code') {
            agent { label 'PRINCIPAL_MAC' }
            steps {
                sh '''
                    echo "===================================================="
                    echo " ETAPA: GET CODE (MAC)"
                    echo "===================================================="
                    whoami && hostname && echo ${WORKSPACE}
                '''
                git 'https://github.com/santt3131/devops_caso1.2.git'
                // Empaquetamos todos los archivos del repo para compartirlos
                // con el resto de agentes que no tienen acceso a este workspace
                stash name: 'source', includes: '**'
            }
        }

        // ETAPA 2: PRUEBAS
        stage('Test') {
            parallel {
                stage('Unit') {
                    agent { label 'PRINCIPAL_MAC' } 
                    steps {
                        // Recuperamos el código fuente en el workspace de PRINCIPAL_MAC
                        unstash 'source'
                        sh '''
                            echo "===================================================="
                            echo "ETAPA: UNIT TEST (PRINCIPAL_MAC)"
                            echo "===================================================="
                            whoami && hostname && echo ${WORKSPACE}
                            
                            export PYTHONPATH=${WORKSPACE}
                            python3 -m coverage run --branch --source=app --omit=app/__init__.py,app/api.py -m pytest --junitxml=result-unit.xml test/unit
                        '''
                         // guarda el .coverage
                        stash name: 'coverage_data', includes: '.coverage' 
                    }
                    post { always { junit 'result-unit.xml' } }
                }
                
                stage('Rest') {
                    agent { label 'MAC-02' } 
                    steps {
                        // Recuperamos el código fuente en el workspace de MAC-02
                        unstash 'source'
                        sh '''
                            echo "===================================================="
                            echo " ETAPA: REST TEST (MAC)"
                            echo "===================================================="
                            whoami && hostname && echo ${WORKSPACE}
                            
                            # Limpieza: Matamos procesos en puertos 5000 y 9090 para evitar el error "Address already in use"
                            lsof -t -i:5000 | xargs kill -9 || true
                            lsof -t -i:9090 | xargs kill -9 || true

                            # Lanzamos la App Flask en segundo plano (&) para que el pipeline pueda seguir
                            export FLASK_APP=app/api.py
                            export FLASK_ENV=development
                            python3 -m flask run & 
                            
                            # Lanzamos WireMock para simular dependencias externas, también en segundo plano
                            java -jar "/Users/santt/Documents/UNIR/1_Curso Devops/CASOS PRACTICOS/REPOS/JAR/wiremock-standalone-4.0.0-beta.29.jar" --port 9090 --root-dir test/wiremock &
                            
                            # Esperamos 5 segundos para que Flask y WireMock estén totalmente listos
                            sleep 5 
                            
                            export PYTHONPATH=${WORKSPACE}
                            # Ejecutamos los tests de integración contra la API
                            python3 -m pytest --junitxml=result-rest.xml test/rest 
                        '''
                    }
                    post { always { junit 'result-rest.xml' } }
                }        
            }
        }

        // ETAPA 3: COBERTURA
        stage('Coverage') {
            agent { label 'MAC-02' }
            steps {
                // Recuperamos el código fuente en el workspace de MAC-02
                unstash 'source'
                //recupera el .coverage de Unit
                unstash 'coverage_data'  
                sh '''
                    echo "===================================================="
                    echo " ETAPA: COVERAGE (MAC-02)"
                    echo "===================================================="
                    whoami && hostname && echo ${WORKSPACE}
                    
                    # Generamos el reporte en formato XML para el plugin
                    python3 -m coverage xml 
                '''

                 // Configuramos los umbrales de calidad (Quality Gates) para líneas y ramas
                recordCoverage tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']], 
                qualityGates: [   
                    [criticality: 'NOTE', integerThreshold: 95, metric: 'LINE', threshold: 95.0],
                    [criticality: 'ERROR', integerThreshold: 85, metric: 'LINE', threshold: 85.0], 
                    [criticality: 'NOTE', integerThreshold: 90, metric: 'BRANCH', threshold: 90.0],
                    [criticality: 'ERROR', integerThreshold: 80, metric: 'BRANCH', threshold: 80.0]
                ]
            }
        }

        // ETAPA 4: ANÁLISIS - STATIC & SECURITY
        stage('Analysis') {
            parallel {
                stage('Static') {
                    agent { label 'PRINCIPAL_MAC' }
                    steps {
                        // Recuperamos el código fuente en el workspace de PRINCIPAL_MAC
                        unstash 'source'
                        sh '''
                            echo "===================================================="
                            echo " ETAPA: STATIC ANALYSIS (MAC)"
                            echo "===================================================="
                            whoami && hostname && echo ${WORKSPACE}
                            python3 -m flake8 --format=pylint --exit-zero app > flake8.out
                        '''
                         recordIssues tools: [flake8(name: 'Flake8', pattern: 'flake8.out')],
                        qualityGates: [
                            [threshold: 8, type: 'TOTAL', unstable: true], 
                            [threshold: 10, type: 'TOTAL', unstable: false]
                        ]
                    }
                }
                stage('Security') {
                    agent { label 'PRINCIPAL_MAC' }
                    steps {
                        // Recuperamos el código fuente en el workspace de PRINCIPAL_MAC
                        unstash 'source'
                        sh '''
                            echo "===================================================="
                            echo  "ETAPA: SECURITY ANALYSIS - (MAC)"
                            echo "===================================================="
                            whoami && hostname && echo ${WORKSPACE}
                            python3 -m bandit --exit-zero -r . -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}"
                        '''
                        recordIssues tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')],
                        qualityGates: [
                        [threshold: 2, type: 'TOTAL', unstable: true], 
                        [threshold: 4, type: 'TOTAL', unstable: false]
                    ]
                    }
                }
            }
        }

        // ETAPA 5: RENDIMIENTO
        stage('Performance') {
            agent { label 'WINDOWS' }
            steps {
                // Recuperamos el código fuente en el workspace de WINDOWS
                unstash 'source'
                bat """
                :: 1. Definir variables de entorno para que Flask sepa qué app ejecutar
                set FLASK_APP=app/api.py
                set FLASK_ENV=development
                
                :: 2. Ejecutar Flask en segundo plano
                start flask run 

                :: 3.Si existe un fichero de resultados de una ejecución anterior, lo borramos
                if exist "${env.WORKSPACE}\\flask.jtl" del /f "${env.WORKSPACE}\\flask.jtl"

                :: 4. Ejecutar JMeter en modo no-GUI (-n) con el plan de pruebas flask.jmx
                ::    -t : ruta al plan de pruebas JMeter
                ::    -l : ruta donde se guardarán los resultados (.jtl)
                "C:\\JMeter\\bin\\jmeter.bat" -n -t "${env.WORKSPACE}\\test\\jmeter\\flask.jmx" -l "${env.WORKSPACE}\\flask.jtl"
            """
                // Publicamos el informe de rendimiento en Jenkins a partir del fichero de resultados
                // generado por JMeter, permitiendo visualizar métricas como tiempos de respuesta y errores
                perfReport sourceDataFiles: 'flask.jtl'
            }
        }
    }
}